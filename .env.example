# ---- Database ----
# Production (MongoDB Atlas):
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/hamza-clothing?retryWrites=true&w=majority
# Local Docker (see docker-compose.yml — host port 27018):
# MONGODB_URI=mongodb://hamza:hamza_secret_2025@127.0.0.1:27018/hamza-clothing?authSource=admin

# ---- Auth (NextAuth) ----
# Generate a secret with:  openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@hamzaclothing.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# ---- Cloudinary (image storage) ----
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# ---- Public site config ----
NEXT_PUBLIC_WHATSAPP_NUMBER=923084265402
NEXT_PUBLIC_SITE_NAME=Hamza Cloth House
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/hamzaclothinghouse
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/hamzaclothinghouse
NEXT_PUBLIC_TIKTOK_URL=https://tiktok.com/@hamzaclothinghouse
NEXT_PUBLIC_GOOGLE_MAPS_URL=https://maps.google.com/?q=Haji+Iqbal+Market+Bohar+Gate+Multan

